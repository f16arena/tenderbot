# ── ОРГАНИЗАЦИЯ ──────────────────────
ORG_NAME=ТОО «Ваша Компания»
ORG_BIN=123456789012

# ── GOSZAKUP ─────────────────────────
GOSZAKUP_TOKEN=ваш_токен_от_api.goszakup.gov.kz
GOSZAKUP_LOGIN=ваш_логин
GOSZAKUP_PASSWORD=ваш_пароль

# ── САМРУК-КАЗЫНА ─────────────────────
SAMRUK_LOGIN=ваш_логин
SAMRUK_PASSWORD=ваш_пароль

# ── ЕТК ──────────────────────────────
ETK_LOGIN=ваш_логин
ETK_PASSWORD=ваш_пароль

# ── TELEGRAM ─────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AABBccdd...
TELEGRAM_CHAT_ID=-100123456789

# ── ЭЦП ──────────────────────────────
ECP_PATH=/path/to/your.p12
ECP_PASSWORD=пароль_от_эцп

# ── БД (Supabase / Postgres) ─────────
# Пусто = локальный SQLite. На проде заполнить из Supabase → Project Settings → Database → URI.
DATABASE_URL=

# ── ВЕБ-ДАШБОРД ──────────────────────
# На macOS порт 5000 занят AirPlay Receiver — используйте 5050 или отключите AirPlay
WEB_HOST=0.0.0.0
WEB_PORT=5000

# ── НАСТРОЙКИ МОНИТОРИНГА ─────────────
SCAN_INTERVAL_SECONDS=30
MIN_LOT_PRICE=1000000
MAX_LOT_PRICE=500000000
KEYWORDS=строительство,поставка,ремонт,IT
REGIONS=Алматы,Астана,Восточно-Казахстанская
